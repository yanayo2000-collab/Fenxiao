# Copy this file to deploy/.env before running docker compose
# Example: cp deploy/.env.example deploy/.env

MYSQL_DATABASE=fenxiao
MYSQL_USER=fenxiao
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-root-password

ADMIN_TOKEN=change-this-admin-token
INTERNAL_DISTRIBUTION_TOKEN=change-this-internal-token
PROFILE_CREATE_TOKEN=change-this-profile-create-token

WEB_ALLOWED_ORIGINS=http://localhost:8088,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
SERVER_PORT=8080
